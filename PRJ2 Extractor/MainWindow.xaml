<Window x:Class="PRJ2_Extractor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TR4 to PRJ"
        Height="355" Width="479"
        MinHeight="355" MinWidth="479"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open..." Click="OpenTr4_Click" InputGestureText="Ctrl+O"/>
                <MenuItem x:Name="SaveAsMenuItem" Header="Save _As..." Click="SaveAs_Click" IsEnabled="False"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem x:Name="OptionsMenuItem" Header="_Options" Visibility="Collapsed">
                <MenuItem x:Name="Tr2PrjLinksMenuItem" Header="_TR2PRJ links" IsCheckable="True"/>
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text=""/>
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="282"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="LightGray" BorderThickness="0,0,1,0">
                <ScrollViewer x:Name="TextureScrollViewer"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              PreviewMouseWheel="TextureScrollViewer_PreviewMouseWheel">
                    <Image x:Name="TextureImage"
                           Width="256" Height="256"
                           Stretch="None"
                           ContextMenuOpening="TextureImage_ContextMenuOpening">
                        <Image.ContextMenu>
                            <ContextMenu>
                                <MenuItem x:Name="SaveTgaMenuItem" Header="Save TGA..." Click="SaveTga_Click"/>
                                <MenuItem Header="Cancel"/>
                            </ContextMenu>
                        </Image.ContextMenu>
                    </Image>
                </ScrollViewer>
            </Border>

            <StackPanel Grid.Column="1" Margin="8">
                <Button x:Name="LoadPrjButton"
                        Content="Load TR2PRJ project..."
                        Height="41" Margin="0,0,0,6"
                        Click="LoadPrj_Click"
                        IsEnabled="False"/>
                <Button x:Name="UnloadPrjButton"
                        Content="Unload TR2PRJ project"
                        Height="41" Margin="0,0,0,6"
                        Click="UnloadPrj_Click"
                        IsEnabled="False"/>
                <GroupBox Header="Copy from TR2PRJ" Margin="0,0,0,6">
                    <StackPanel Margin="8">
                        <CheckBox x:Name="CopyDoorsCheckBox"
                                  Content="Doors"
                                  Visibility="Collapsed"
                                  IsEnabled="False"
                                  ToolTip="May cause errors in geometry"/>
                        <CheckBox x:Name="CopyTexturesCheckBox"
                                  Content="Textures"
                                  IsEnabled="False"
                                  ToolTip="Some errors in NGLE"/>
                        <CheckBox x:Name="CopyLightsCheckBox"
                                  Content="Lights"
                                  IsEnabled="False"/>
                    </StackPanel>
                </GroupBox>
                <ProgressBar x:Name="LoadProgressBar"
                             Height="23"
                             Minimum="0" Maximum="100"
                             Value="0"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
